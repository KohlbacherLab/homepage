        "@vuecs/link": "^1.0.0",
        "@vuecs/preset-font-awesome": "^1.1.0",
        "eslint": "^10.1.0",
        "eslint-import-resolver-node": "^0.3.9",
        "eslint-plugin-vue": "^10.8.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.2.3",
        "rimraf": "^6.0.1",
        "typescript": "^5.8.3",
        "typescript-eslint": "^8.57.1",
        "vue-tsc": "^3.2.6"
    },
    "dependencies": {
